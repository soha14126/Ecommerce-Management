# PRODUCTION ENVIRONMENT VARIABLES (For Render.com)

# Database Connection (Get these from Aiven.io or TiDB Cloud)
DB_HOST=your-database-host.com
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=online_shopping
DB_PORT=3306

# Set this to "true" for Render/Cloud Database
DB_SSL=true

# Authentication
JWT_SECRET=any_long_random_string_for_production
PORT=10000

# Production mode
NODE_ENV=production
